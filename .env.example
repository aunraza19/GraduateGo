# This file is auto-loaded from project root/.env when backend starts.

# Required: Gemini API key
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Override Gemini model
# Free-tier friendly: gemini-2.5-flash-image (typically 1K output)
# Higher resolution (2K): gemini-3.1-flash-image-preview (requires available quota)
GEMINI_MODEL=gemini-2.5-flash-image

# Optional: Comma-separated reference image paths.
# Paths can be absolute or relative to backend/.
# Example:
# GEMINI_REFERENCE_IMAGES=static/inputs/reference_1.jpg,static/inputs/reference_2.jpg
GEMINI_REFERENCE_IMAGES=

# Optional but recommended for reliable mobile QR scanning on local WiFi
# Example: 192.168.1.50
LOCAL_IP=
