# This file is auto-loaded from project root/.env when backend starts.

# Required: OpenAI API key
OPENAI_API_KEY=your_openai_api_key_here

# Optional: GPT Image model (requested default)
OPENAI_IMAGE_MODEL=gpt-image-1.5

# Optional: Comma-separated reference image paths.
# Paths can be absolute or relative to backend/.
# Example:
# OPENAI_REFERENCE_IMAGES=static/inputs/reference1.jpg,static/inputs/reference2.jpg
OPENAI_REFERENCE_IMAGES=

# Optional output tuning
# OPENAI_IMAGE_SIZE=1024x1024
# OPENAI_IMAGE_QUALITY=high
# OPENAI_IMAGE_FORMAT=jpeg

# Optional but recommended for reliable mobile QR scanning on local WiFi
# Example: 192.168.1.50
LOCAL_IP=

# Gmail SMTP delivery (recommended for sending images to users)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_gmail_app_password
FROM_EMAIL=your_gmail@gmail.com
SMTP_USE_TLS=true
# SMTP_USE_SSL=false
